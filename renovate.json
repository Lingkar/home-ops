{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:best-practices",
    ":dependencyDashboard",
    ":semanticCommits",
    ":separateMultipleMajorReleases",
    ":separatePatchReleases",
    ":prHourlyLimitNone",
    ":prConcurrentLimitNone"
  ],
  "dependencyDashboardTitle": "Renovate Dashboard 🤖",
  "platformAutomerge": true,
  "ignorePaths": [
    "**/*.sops.*"
  ],
  "flux": {
    "managerFilePatterns": [
      "/(^|/)kubernetes/.+\\.ya?ml$/"
    ]
  },
  "helm-values": {
    "managerFilePatterns": [
      "/(^|/)values(-[a-z0-9])?\\.ya?ml$/"
    ]
  },
  "kubernetes": {
    "managerFilePatterns": [
      "/(^|/)kubernetes/.+\\.ya?ml$/"
    ]
  },
  "packageRules": [
    {
      "description": "Flux commit metadata",
      "matchManagers": [
        "flux"
      ],
      "semanticCommitScope": "flux"
    },
    {
      "description": "Disable digest pinning for Flux Docker sources", //TODO: https://github.com/renovatebot/renovate/issues/29768
      "matchManagers": [
        "flux"
      ],
      "matchDatasources": [
        "docker"
      ],
      "matchFileNames": [
        "**/kubernetes/**/source.yaml",
        "**/kubernetes/**/source.yml"
      ],
      "pinDigests": false
    },
    {
      "description": "Disable digest pinning for talenv",
      "matchManagers": [
        "custom.regex"
      ],
      "matchFileNames": [
        "talos/talenv.yaml"
      ],
      "pinDigests": false
    },
    {
      "description": "Disable digest pinning for helmfile",
      "matchManagers": [
        "helmfile"
      ],
      "pinDigests": false
    },
    // Update policies
    {
      "description": "Flux Operator Group",
      "groupName": "flux-operator",
      "matchDatasources": [
        "docker"
      ],
      "matchPackageNames": [
        "/flux-operator/",
        "/flux-instance/"
      ],
      "group": {
        "commitMessageTopic": "{{{groupName}}} group"
      },
      "minimumGroupSize": 2
    },
    {
      "description": "Patch updates",
      "matchManagers": [
        "flux",
        "helm-values",
        "kubernetes",
        "github-actions",
        "mise"
      ],
      "matchUpdateTypes": [
        "patch"
      ],
      "minimumReleaseAge": "5 days",
      "automerge": true
    },
    {
      "description": "Minor updates",
      "matchManagers": [
        "flux",
        "helm-values",
        "kubernetes",
        "github-actions",
        "mise"
      ],
      "matchUpdateTypes": [
        "minor"
      ],
      "minimumReleaseAge": "10 days",
      "automerge": false,
      "autoApprove": false
    },
    {
      "description": "Major updates",
      "matchManagers": [
        "flux",
        "helm-values",
        "kubernetes",
        "github-actions",
        "mise"
      ],
      "matchUpdateTypes": [
        "major"
      ],
      "minimumReleaseAge": "20 days",
      "automerge": false,
      "autoApprove": false
    },
    // Commit messages & labels
    {
      "matchUpdateTypes": [
        "major"
      ],
      "semanticCommitType": "feat",
      "commitMessagePrefix": "{{semanticCommitType}}({{semanticCommitScope}})!:",
      "commitMessageExtra": "( {{currentVersion}} ➔ {{newVersion}} )",
      "labels": [
        "type/major"
      ]
    },
    {
      "matchUpdateTypes": [
        "minor"
      ],
      "semanticCommitType": "feat",
      "commitMessageExtra": "( {{currentVersion}} ➔ {{newVersion}} )",
      "labels": [
        "type/minor"
      ]
    },
    {
      "matchUpdateTypes": [
        "patch"
      ],
      "semanticCommitType": "fix",
      "commitMessageExtra": "( {{currentVersion}} ➔ {{newVersion}} )",
      "labels": [
        "type/patch"
      ]
    },
    {
      "matchUpdateTypes": [
        "digest"
      ],
      "semanticCommitType": "chore",
      "commitMessageExtra": "( {{currentDigestShort}} ➔ {{newDigestShort}} )"
    },
    {
      "matchDatasources": [
        "docker"
      ],
      "semanticCommitScope": "container",
      "commitMessageTopic": "image {{depName}}",
      "addLabels": [
        "renovate/container"
      ]
    },
    {
      "matchDatasources": [
        "helm"
      ],
      "semanticCommitScope": "helm",
      "commitMessageTopic": "chart {{depName}}",
      "addLabels": [
        "renovate/helm"
      ]
    },
    {
      "matchManagers": [
        "github-actions"
      ],
      "semanticCommitType": "ci",
      "semanticCommitScope": "github-action",
      "commitMessageTopic": "action {{depName}}",
      "addLabels": [
        "renovate/github-action"
      ]
    },
    {
      "matchDatasources": [
        "github-releases"
      ],
      "semanticCommitScope": "github-release",
      "commitMessageTopic": "release {{depName}}",
      "addLabels": [
        "renovate/github-release"
      ]
    },
    {
      "matchManagers": [
        "mise"
      ],
      "semanticCommitScope": "mise",
      "commitMessageTopic": "tool {{depName}}"
    }
  ],
  "customManagers": [
    {
      "description": "Process annotated dependencies",
      "customType": "regex",
      "managerFilePatterns": [
        "/(^|/).+\\.env(?:\\.j2)?$/",
        "/(^|/).+\\.sh(?:\\.j2)?$/",
        "/(^|/).+\\.ya?ml(?:\\.j2)?$/"
      ],
      "matchStrings": [
        "datasource=(?<datasource>\\S+) depName=(?<depName>\\S+)( repository=(?<registryUrl>\\S+))?\\n.+(:\\s|=)(&\\S+\\s)?(?<currentValue>\\S+)",
        "datasource=(?<datasource>\\S+) depName=(?<depName>\\S+)\\n.+/(?<currentValue>(v|\\d)[^/]+)"
      ],
      "datasourceTemplate": "{{#if datasource}}{{{datasource}}}{{else}}github-releases{{/if}}"
    }
  ]
}
